<script>
// ZAHATORTE YouTube IFrame Player API
var zahaPlayer;
function onYouTubeIframeAPIReady(){
  zahaPlayer=new YT.Player('zaha-yt-player',{
    videoId:'ahK4a9eE8WA',
    playerVars:{autoplay:1,mute:1,loop:1,playlist:'ahK4a9eE8WA',rel:0,controls:1},
    events:{onReady:function(e){e.target.playVideo();}}
  });
}
function zahaUnmute(){
  if(zahaPlayer){
    zahaPlayer.unMute();
    zahaPlayer.setVolume(60);
  }
  document.getElementById('zahaSoundBtn').classList.add('hidden');
}
(function(){
  var tag=document.createElement('script');
  tag.src='https://www.youtube.com/iframe_api';
  document.head.appendChild(tag);
})();
</script>
<script>
// Hero live banner（残り14日以内に自動表示）
(function(){
  var evs2=[
    {d:new Date('2026-05-24T00:00:00+09:00'),name:'ZAHATORTE',disp:'5月24日（日）',url:'event-zahatorte.html'},
    {d:new Date('2026-06-05T00:00:00+09:00'),name:'黒色すみれ',disp:'6月5日（金）',url:'event-kuroshikisumire.html'},
    {d:new Date('2026-06-14T00:00:00+09:00'),name:'蜂鳥あみ太',disp:'6月14日（日）',url:'event-hachinoko.html'}
  ];
  var now=new Date();
  var jstMs=now.getTime()+9*3600*1000;
  var todayJST=new Date(Math.floor(jstMs/86400000)*86400000-9*3600*1000);
  var next=evs2.map(function(e){return{days:Math.round((e.d-todayJST)/86400000),name:e.name,disp:e.disp,url:e.url};})
    .filter(function(e){return e.days>=0&&e.days<=14;})
    .sort(function(a,b){return a.days-b.days;})[0];
  if(next){
    document.getElementById('heroLiveBannerLink').href=next.url;
    document.getElementById('hlbName').textContent=next.name;
    document.getElementById('hlbDate').textContent=next.disp;
    var wrap=document.getElementById('hlbDaysWrap');
    if(next.days===0){wrap.innerHTML='<strong style="color:#e8c88a">今日開催！</strong>';}
    else if(next.days===1){wrap.innerHTML='<strong style="color:#e8c88a">明日！</strong>';}
    else{document.getElementById('hlbDays').textContent=next.days;}
    document.getElementById('heroLiveBanner').style.display='block';
  }
})();
// イベントカードのカウントダウン
(function(){
  var evs=[
    {id:'top-zahatorte',       date:'2026-05-24'},
    {id:'idx-zahatorte',       date:'2026-05-24'},
    {id:'idx-kuroshikisumire', date:'2026-06-05'},
    {id:'idx-hachinoko',       date:'2026-06-14'}
  ];
  var n=new Date(), today=new Date(n.getFullYear(),n.getMonth(),n.getDate());
  evs.forEach(function(ev){
    var p=ev.date.split('-');
    var diff=Math.round((new Date(+p[0],+p[1]-1,+p[2])-today)/86400000);
    var el=document.getElementById('cd-'+ev.id);
    if(!el) return;
    var text,cls='event-cd-sm';
    if(diff>1){ text='🗓 あと '+diff+' 日'; }
    else if(diff===1){ text='✦ いよいよ明日！'; }
    else if(diff===0){ text='🎵 本日開催！'; cls+=' cd-today'; }
    else { return; }
    el.textContent=text; el.className=cls; el.style.display='inline-block';
  });
})();
</script>
<script>(function(){var p=new URLSearchParams(location.search);if(p.get("owner")==="nora")localStorage.setItem("nora_owner","1");if(p.get("owner")==="off")localStorage.removeItem("nora_owner");if(!localStorage.getItem("nora_owner"))fetch("https://noratool.pythonanywhere.com/pv?p="+encodeURIComponent(location.pathname)).catch(function(){});})();</script>
