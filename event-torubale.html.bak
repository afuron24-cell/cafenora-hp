  <script>
    var liveDate = new Date('2026-08-02T00:00:00+09:00');
    function updateCD() {
      var now = new Date();
      var jstMs = now.getTime() + 9 * 3600 * 1000;
      var todayJST = new Date(Math.floor(jstMs / 86400000) * 86400000 - 9 * 3600 * 1000);
      var diff = Math.round((liveDate - todayJST) / 86400000);
      if (diff > 0) {
        document.getElementById('hero-days').textContent = diff;
        if (diff <= 7) document.getElementById('urgency-banner').classList.remove('hidden');
      } else {
        document.getElementById('hero-cd').textContent = '開催当日！';
      }
    }
    updateCD();
  </script>
<script>(function(){var p=new URLSearchParams(location.search);if(p.get("owner")==="nora")localStorage.setItem("nora_owner","1");if(p.get("owner")==="off")localStorage.removeItem("nora_owner");if(!localStorage.getItem("nora_owner"))fetch("https://noratool.pythonanywhere.com/pv?p="+encodeURIComponent(location.pathname)).catch(function(){});})();</script>
<script>
(function(){
  var cd=document.querySelector('.gs-hero-cd');
  if(!cd) return;
  function flash(){
    cd.style.transition='none';
    cd.style.borderColor='rgba(255,245,180,1)';
    cd.style.boxShadow='0 0 14px 5px rgba(255,235,120,1),0 0 40px 12px rgba(201,169,97,0.8),0 0 80px 24px rgba(201,169,97,0.35),inset 0 0 20px rgba(201,169,97,0.25)';
    setTimeout(function(){
      cd.style.transition='border-color 1.4s ease-out,box-shadow 1.4s ease-out';
      cd.style.borderColor='rgba(201,169,97,.35)';
      cd.style.boxShadow='none';
      setTimeout(flash,1400+700+Math.random()*2000);
    },180);
  }
  setTimeout(flash,2600);
})();
</script>

<script>
/* live ticker countdown */
(function(){
  var lives=[
    {id:'kuroshikisumire',date:'2026-06-05'},
    {id:'hachinoko',      date:'2026-06-14'},
    {id:'karitomato',     date:'2026-07-28'},
    {id:'torubale',       date:'2026-08-02'}
  ];
  var n=new Date(), today=new Date(n.getFullYear(),n.getMonth(),n.getDate());
  lives.forEach(function(lv){
    var p=lv.date.split('-');
    var diff=Math.round((new Date(+p[0],+p[1]-1,+p[2])-today)/86400000);
    var bar=document.getElementById('lb-'+lv.id);
    var el=document.getElementById('lbd-'+lv.id);
    if(!bar||!el) return;
    if(diff<0){ bar.style.display='none'; return; }
    if(diff===0){ el.innerHTML='<strong>本日！</strong>'; el.classList.add('lt-today'); }
    else if(diff===1){ el.innerHTML='<strong>明日</strong>'; el.classList.add('lt-today'); }
    else{ el.innerHTML='あと<strong>'+diff+'日</strong>'; }
  });
  (function(){
    var rows=[
      {rowId:'lt-row1',ids:['kuroshikisumire','hachinoko'],sepId:'lbs-r1'},
      {rowId:'lt-row2',ids:['karitomato','torubale'],sepId:'lbs-r2'}
    ];
    rows.forEach(function(r){
      var vis=r.ids.map(function(id){var el=document.getElementById('lb-'+id);return el&&el.style.display!=='none';});
      var sep=document.getElementById(r.sepId);
      if(sep) sep.style.display=(vis[0]&&vis[1])?'':'none';
      var row=document.getElementById(r.rowId);
      if(row&&!vis[0]&&!vis[1]) row.style.display='none';
    });
  })();
})();
</script>
