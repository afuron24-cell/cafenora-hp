<script>
function switchLayout(n) {
  document.querySelectorAll('.ls-content').forEach(function(el){ el.style.display='none'; });
  document.querySelectorAll('.ls-btn').forEach(function(btn){ btn.classList.remove('active'); });
  document.getElementById('layout'+n).style.display='block';
  document.querySelectorAll('.ls-btn')[n-1].classList.add('active');
}
</script>

