<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>cafe nora（カフェノラ）| 愛媛県新居浜市 自家焙煎コーヒー・まるヨガ</title>
  <meta name="google-site-verification" content="YEt6vmIiWF3QRi9HjYwVf3zzIji54vVVu73euAuqCdQ" />
  <meta name="description" content="愛媛県新居浜市のカフェノラ（cafe nora）。手まわし焙煎の自家焙煎コーヒー、玄米ランチ、天然酵母パン、まるヨガ、ライブイベント。新居浜市萩生のちいさなカフェです。">
  <meta property="og:title" content="cafe nora | 愛媛県新居浜市のカフェ・まるヨガ">
  <meta property="og:description" content="手まわし焙煎コーヒー・玄米プレート・ヨガ・ライブイベント。新居浜市のちいさなカフェです。">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://cafenora.jp/">
  <meta property="og:image" content="https://cafenora.jp/images/hero.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CafeOrCoffeeShop",
    "name": "cafe nora",
    "alternateName": "カフェノラ",
    "url": "https://cafenora.jp",
    "image": "https://cafenora.jp/images/hero.jpg",
    "telephone": "090-9459-1733",
    "address": {
      "@type": "PostalAddress",
      "postalCode": "792-0050",
      "addressRegion": "愛媛県",
      "addressLocality": "新居浜市",
      "streetAddress": "萩生2133-29"
    },
    "openingHours": ["Mo 10:00-15:00", "Th 10:00-15:00", "Fr 10:00-15:00"],
    "servesCuisine": ["コーヒー", "玄米ランチ", "天然酵母パン"],
    "priceRange": "¥",
    "description": "愛媛県新居浜市のカフェ。手まわし焙煎の自家焙煎コーヒー、玄米ランチ、天然酵母パン、まるヨガ、ライブイベント。",
    "hasMap": "https://maps.google.com/maps?q=愛媛県新居浜市萩生2133-29"
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@300;400;500;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/style.css">
  <style>
    .event-cd-sm{display:none;background:rgba(201,169,110,.1);border:1px solid rgba(201,169,110,.35);border-radius:20px;padding:.28rem .75rem;font-size:.75rem;color:#a07840;margin:.4rem 0 .5rem;letter-spacing:.04em;font-weight:500;}
    .event-cd-sm.cd-today{background:rgba(192,57,43,.08);border-color:rgba(192,57,43,.4);color:#c0392b;font-weight:700;}
    .event-credential{font-size:.72rem;color:#9b7a4a;letter-spacing:.06em;margin:.25rem 0 .5rem;line-height:1.5;border-left:2px solid #c9a96e;padding-left:.55rem;}
    .events-hook{text-align:center;margin-bottom:2rem;}
    .events-hook-lead{font-size:.92rem;color:#7a6248;line-height:1.9;margin-bottom:1.2rem;}
    .events-hook-lead em{font-style:normal;font-weight:700;color:#4a3728;}
    .btn-hook{display:inline-block;background:#4a3728;color:#f5ede0;padding:.75rem 2rem;border-radius:2px;font-size:.88rem;letter-spacing:.12em;text-decoration:none;transition:background .2s,transform .15s;font-weight:500;}
    .btn-hook:hover{background:#2d1f14;transform:translateY(-2px);}
    /* ─── Live Ticker（ヘッダー内・ダーク） ─── */
    .live-ticker{background:#1a0e2e;padding:7px 1.5rem 10px;display:flex;flex-direction:column;align-items:center;gap:4px;}
    .lt-label{font-size:.6rem;font-weight:700;letter-spacing:.28em;color:#c9a96e;text-align:center;margin-bottom:1px;text-transform:uppercase;}
    .lt-row{display:flex;align-items:center;justify-content:center;gap:0;flex-wrap:nowrap;}
    .lt-item{display:inline-flex;align-items:center;gap:5px;color:#e8e0f4;text-decoration:none;font-size:.82rem;letter-spacing:.02em;padding:1px 12px;transition:color .2s;white-space:nowrap;}
    .lt-item:hover{color:#c9a96e;}
    .lt-idate{font-family:'Playfair Display',serif;font-size:.8rem;color:rgba(201,169,110,.8);font-style:italic;letter-spacing:.08em;}
    .lt-iname{font-size:.8rem;font-weight:500;}
    .lt-idays{font-size:.64rem;color:rgba(255,255,255,.38);margin-left:1px;}
    .lt-idays strong{color:#c9a96e;}
    .lt-idays.lt-today strong{color:#f08060;}
    .lt-new{display:inline-block;background:#e53935;color:#fff;font-size:.44rem;font-weight:700;padding:.04rem .22rem;border-radius:2px;letter-spacing:.1em;vertical-align:middle;margin-left:2px;line-height:1.4;}
    .lt-sep{color:rgba(201,169,110,.3);font-size:.85rem;flex-shrink:0;line-height:1;}
    /* ─── Hero buttons 3列グリッド ─── */
    .hero-sumire-card{display:flex;flex-direction:column;align-items:center;gap:.3rem;background:rgba(55,30,10,.45);border:1px solid rgba(210,175,100,.68);border-radius:16px;padding:.75rem 1.2rem 1rem;margin:1rem 0 .9rem;backdrop-filter:blur(8px);}
    .hero-sumire-badge{font-size:.65rem;letter-spacing:.22em;color:var(--gold,#C9A961);background:rgba(201,169,97,.15);border:1px solid rgba(201,169,97,.4);border-radius:20px;padding:.18rem .7rem;}
    .hero-sumire-name{font-size:1.25rem;font-weight:700;color:#fff;letter-spacing:.12em;margin:0;}
    .hero-sumire-sub{font-size:.75rem;color:rgba(255,255,255,.65);letter-spacing:.06em;margin:0;}
    .hero-sumire-cd{font-size:.8rem;color:rgba(201,169,97,.9);letter-spacing:.04em;margin:.1rem 0 .35rem;}
    .hero-sumire-cd strong{font-size:1.5rem;font-weight:700;color:#C9A961;}
    .hero-sumire-link{font-size:.78rem;color:#C9A961;text-decoration:none;border-bottom:1px solid rgba(201,169,97,.4);padding-bottom:.08rem;letter-spacing:.06em;}
    .hero-sumire-link:hover{border-bottom-color:#C9A961;}
    .hero-amita-days{font-size:.95rem;font-weight:800;letter-spacing:.05em;margin:.05rem 0 .4rem;background:linear-gradient(90deg,#ff5a4d,#ffd76e,#ff5a4d);background-size:220% auto;-webkit-background-clip:text;background-clip:text;color:transparent;animation:amita-text-shimmer 2.4s linear infinite;}
    @keyframes amita-text-shimmer{0%{background-position:0% center;}100%{background-position:220% center;}}
    /* ── 黒色すみれ LIVE当日 きらきら ── */
    @keyframes sumire-glow{0%,100%{box-shadow:0 0 18px rgba(201,169,97,.4),0 0 42px rgba(160,100,220,.25),inset 0 0 14px rgba(201,169,97,.07);border-color:rgba(215,180,110,.85);}50%{box-shadow:0 0 36px rgba(201,169,97,.72),0 0 68px rgba(160,100,220,.48),inset 0 0 22px rgba(201,169,97,.13);border-color:#e8cc68;}}
    @keyframes sumire-badge-shine{0%,100%{background:rgba(201,169,97,.22);color:#f5da7a;letter-spacing:.24em;}50%{background:rgba(201,169,97,.4);color:#fff2a8;letter-spacing:.28em;}}
    @keyframes sumire-name-glow{0%,100%{text-shadow:0 0 22px rgba(201,169,97,.55),0 0 6px rgba(255,255,255,.2);}50%{text-shadow:0 0 40px rgba(201,169,97,.88),0 0 16px rgba(255,220,100,.4),0 0 60px rgba(180,120,240,.2);}}
    @keyframes sumire-spark-spin{0%{opacity:0;transform:scale(0) rotate(0deg);}40%{opacity:1;transform:scale(1.25) rotate(180deg);}100%{opacity:0;transform:scale(0) rotate(360deg);}}
    .hero-sumire-badge{color:#f5da7a!important;background:rgba(201,169,97,.22)!important;border-color:rgba(201,169,97,.65)!important;animation:sumire-badge-shine 1.7s ease-in-out infinite;}
    .hero-sumire-name{animation:sumire-name-glow 2.3s ease-in-out infinite;}
    .hero-sumire-today{font-size:.88rem;font-weight:700;color:#f5da7a;letter-spacing:.08em;margin:.05rem 0 .3rem;animation:sumire-badge-shine 1.7s ease-in-out .4s infinite;}
    .hero-btn-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin-bottom:.85rem;}
    .hero-btn-grid .btn-primary,.hero-btn-grid .btn-outline{width:100%;text-align:center;padding:.6rem .5rem;font-size:.82rem;box-sizing:border-box;white-space:nowrap;}
    @keyframes new-pulse{0%,100%{opacity:1;}50%{opacity:.7;}}
    .event-new-badge{position:absolute;top:.7rem;left:.7rem;z-index:10;background:#e03030;color:#fff;font-size:.62rem;font-weight:800;padding:.2rem .55rem;border-radius:.25rem;letter-spacing:.14em;box-shadow:0 2px 6px rgba(224,48,48,.4);animation:new-pulse 1.8s ease-in-out infinite;}

    /* ── Hero enhanced（トップページ専用） ── */
    .hero-content{animation:none;}
    .hero-img{opacity:.50;}
    .hero-overlay{
      position:absolute;inset:0;
      background:
        linear-gradient(165deg, rgba(12,25,10,.40) 0%, transparent 52%),
        linear-gradient(to bottom, rgba(12,25,10,.08) 0%, rgba(12,25,10,.75) 100%);
    }
    @keyframes heroReveal{
      from{opacity:0;transform:translateY(18px);}
      to  {opacity:1;transform:translateY(0);}
    }
    .hero-eyebrow{
      font-family:'Playfair Display',serif;
      font-size:.72rem;letter-spacing:.42em;
      color:rgba(210,198,158,.82);
      text-transform:uppercase;
      margin-bottom:.65rem;
      opacity:0;animation:heroReveal 1s cubic-bezier(.16,1,.3,1) .15s forwards;
    }
    .hero-tagline{opacity:0;animation:heroReveal 1s cubic-bezier(.16,1,.3,1) .38s forwards;}
    .hero-title{
      opacity:0;animation:heroReveal 1.2s cubic-bezier(.16,1,.3,1) .62s forwards;
      text-shadow:0 0 70px rgba(160,210,130,.15),0 2px 24px rgba(0,0,0,.45);
    }
    .hero-sumire-card{opacity:0;animation:heroReveal 1s cubic-bezier(.16,1,.3,1) 1.05s forwards,sumire-glow 2.8s ease-in-out 2.1s infinite;}
    @keyframes amita-glow-flicker{
      0%,100%{box-shadow:0 0 16px rgba(224,48,48,.45),0 0 34px rgba(201,169,97,.22);border-color:rgba(224,48,48,.65);}
      22%{box-shadow:0 0 30px rgba(245,218,122,.6),0 0 18px rgba(224,48,48,.25);border-color:#f5da7a;}
      41%{box-shadow:0 0 14px rgba(224,48,48,.35),0 0 40px rgba(201,169,97,.45);border-color:rgba(232,160,80,.75);}
      63%{box-shadow:0 0 36px rgba(224,48,48,.6),0 0 20px rgba(245,218,122,.4);border-color:#e03030;}
      85%{box-shadow:0 0 22px rgba(245,218,122,.5),0 0 38px rgba(224,48,48,.28);border-color:#f5da7a;}
    }
    .hero-sumire-card.amita-blaze{animation:heroReveal 1s cubic-bezier(.16,1,.3,1) 1.05s forwards,amita-glow-flicker 3.4s ease-in-out 2.1s infinite;}
    .hero-btn-grid{opacity:0;animation:heroReveal 1s cubic-bezier(.16,1,.3,1) 1.28s forwards;}
    .hero-access-link{opacity:0;animation:heroReveal .9s cubic-bezier(.16,1,.3,1) 1.48s forwards;}
    .hero-notice{font-size:.8rem;color:#C9A961;background:rgba(201,169,97,.15);border:1px solid rgba(201,169,97,.5);border-radius:20px;padding:.35rem 1.1rem;margin:.6rem auto .2rem;display:inline-block;letter-spacing:.07em;opacity:0;animation:heroReveal .9s cubic-bezier(.16,1,.3,1) .85s forwards;}
  </style>
  <link rel="canonical" href="https://cafenora.jp/">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#7a9e7e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="cafe nora">
  <link rel="apple-touch-icon" href="/images/icon-192.png">
  <script src=https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js defer></script>
  <script>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(async function(OneSignal) {
      await OneSignal.init({
        appId: 'f214c199-2cb9-4e02-90d4-91ca8462d321',
        notifyButton: { enable: false }
      });
      if (Notification.permission === 'granted' && !OneSignal.User.PushSubscription.optedIn) {
        await OneSignal.User.PushSubscription.optIn();
      }
    });
  </script>
</head>
<body>

  <header class="header" id="header">
    <div class="header-inner">
      <div class="header-left"><a href="/" class="logo">
        <span class="logo-en">cafe nora</span>
        <span class="logo-jp">カフェ ノラ</span>
      </a><a href="parking.html" class="parking-badge">🚗 臨時駐車場</a></div>
      <button class="menu-btn" id="menuBtn" aria-label="メニューを開く">
        <span></span><span></span><span></span>
      </button>
      <nav class="nav" id="nav">
        <ul class="nav-list">
          <li><a href="cafe.html">カフェ</a></li>
          <li><a href="calendar.html">カレンダー</a></li>
          <li><a href="events.html">イベント</a></li>
          <li><a href="popup.html">出店情報</a></li>
          <li><a href="access.html">アクセス</a></li>
          <li><a href="service.html">HP制作</a></li>
          <li><a href="notifications.html">お知らせ</a></li>
          <li><a href="contact.html">お問い合わせ</a></li>
        </ul>
      </nav>
    </div>
    <!-- ライブ告知ティッカー -->
    <div class="live-ticker">
      <span class="lt-label">LIVE</span>
      <div class="lt-row" id="lt-row1">
        <a href="event-hachinoko.html" class="lt-item" id="lb-hachinoko">
          <span class="lt-idate">6.14</span>
          <span class="lt-iname">蜂鳥あみ太</span>
          <span class="lt-idays" id="lbd-hachinoko"></span>
        </a>
        <span class="lt-sep" id="lbs-r1">·</span>
        <a href="event-karitomato.html" class="lt-item" id="lb-karitomato-t1">
          <span class="lt-idate">7.28</span>
          <span class="lt-iname">カリトマト</span>
          <span class="lt-idays" id="lbd-karitomato-t1"></span>
        </a>
      </div>
      <div class="lt-row" id="lt-row2">
        <a href="event-karitomato.html" class="lt-item" id="lb-karitomato">
          <span class="lt-idate">7.28</span>
          <span class="lt-iname">カリトマト<span class="lt-new">NEW</span></span>
          <span class="lt-idays" id="lbd-karitomato"></span>
        </a>
        <span class="lt-sep" id="lbs-r2">·</span>
        <a href="event-torubale.html" class="lt-item" id="lb-torubale">
          <span class="lt-idate">8.2</span>
          <span class="lt-iname">とぅるばーる</span>
          <span class="lt-idays" id="lbd-torubale"></span>
        </a>
      </div>
    </div>
  </header>
<script>
  (function(){
    var hdr = document.getElementById('header');
    var hero = document.querySelector('.hero, .gs-hero');
    if(hdr && hero){
      hero.style.paddingTop = hdr.offsetHeight + 'px';
      window.addEventListener('resize', function(){
        hero.style.paddingTop = hdr.offsetHeight + 'px';
      });
    }
  })();
</script>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="images/hero.jpg" alt="cafe nora の雰囲気" class="hero-img">
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-content">
      <p class="hero-eyebrow">✦ &thinsp; cafe nora &thinsp; ✦</p>
      <p class="hero-tagline">愛媛県新居浜市・小さなカフェ</p>
      <h1 class="hero-title">おいしいコーヒーと<br><em>パンに会える店</em></h1>
      <div class="hero-sumire-card amita-blaze" id="hero-amita-card">
        <span class="hero-sumire-badge">✦ NEXT LIVE ✦</span>
        <p class="hero-sumire-name">蜂鳥あみ太＝４号</p>
        <p class="hero-sumire-sub">日本凱旋TOUR</p>
        <p class="hero-sumire-cd">6月14日（日）開場 <strong>15:00</strong> / 開演 15:30</p>
        <p class="hero-amita-days" id="hero-amita-days"></p>
        <a href="event-hachinoko.html" class="hero-sumire-link">詳細・ご予約はこちら →</a>
      </div>
      <div class="hero-btn-grid">
        <a href="cafe.html" class="btn-primary">カフェ</a>
        <a href="events.html" class="btn-outline">イベント</a>
        <a href="maruyoga/" class="btn-outline">まるヨガ</a>
      </div>
      <div class="hero-access-link">
        <a href="#access-guide" class="btn-access-jump">
          <span class="access-jump-icon">📍</span>
          初めての方へ：カフェへの道順はこちら
          <span class="access-jump-arrow">↓</span>
        </a>
      </div>
    </div>

    <div class="hero-scroll">
      <span class="scroll-text">scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- 3つの柱 -->
  <section class="pillars section">
    <div class="container">
      <div class="section-header fade-in">
        <p style="font-size:.68rem;letter-spacing:.3em;color:var(--color-primary);margin-bottom:.7rem;text-transform:uppercase;">About</p>
        <h2 class="section-title">cafe nora について</h2>
        <p class="section-lead">カフェ・ヨガ・ライブイベントの3つを軸に、<br>地域の小さなコミュニティの場として活動しています。</p>
      </div>
      <div class="pillars-grid">
        <!-- カフェ：2枚の写真を重ねる -->
        <div class="pillar-card fade-in">
          <div class="pillar-img-wrap pillar-dual">
            <img src="images/mame.jpg" alt="自家焙煎コーヒー豆" class="dual-img-back">
            <img src="images/pan.jpg" alt="天然酵母パン" class="dual-img-front">
          </div>
          <div class="pillar-body">
            <h3 class="pillar-title">カフェ</h3>
            <p class="pillar-text">手まわし焙煎機による自家焙煎コーヒー。<br>玄米プレートや野菜たっぷりのランチ、<br>天然酵母パン、有機ドリンクなど。<br>ランチ・ドリンクのテイクアウトや<br>コーヒー豆の販売もしています。</p>
            <a href="cafe.html" class="pillar-link">くわしく見る <span>→</span></a>
          </div>
        </div>
        <div class="pillar-card fade-in">
          <div class="pillar-img-wrap">
            <img src="images/ryoko-maruyoga.jpg" alt="まるヨガ・金丸良子" class="pillar-img">
          </div>
          <div class="pillar-body">
            <h3 class="pillar-title">まるヨガ</h3>
            <p class="pillar-text">古典・ハタヨガクラス。14年のキャリアを持つ<br>インストラクター・金丸良子が指導。<br>心と体を整える時間を。</p>
            <a href="maruyoga/" class="pillar-link">まるヨガ専用サイトへ <span>→</span></a>
          </div>
        </div>
        <div class="pillar-card fade-in">
          <div class="pillar-img-wrap">
            <img src="images/pillar-event.svg" alt="ライブ・イベント" class="pillar-img">
          </div>
          <div class="pillar-body">
            <h3 class="pillar-title">ライブ・イベント</h3>
            <p class="pillar-text">様々なアーティストを迎えて個性的なライブを<br>しています。地域のコミュニティの場として、<br>心に残るひとときをお届けします♫</p>
            <a href="events.html" class="pillar-link">くわしく見る <span>→</span></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 出店情報 -->
  <section class="section" style="background:#f9f5f0; padding:56px 24px;">
    <div class="container">
      <div class="section-header fade-in">
        <h2 class="section-title">近日の出店・参加イベント</h2>
        <p class="section-lead">cafe noraがマルシェやクラフトフェアに出店します。<br>ぜひ会いに来てください。</p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:20px; max-width:860px; margin:0 auto;" class="fade-in">
        <!-- ★曜日はpopup.htmlと必ず合わせる -->
        <a href="popup.html#craftwork" style="text-decoration:none;">
          <div style="background:white; border-radius:12px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.08); transition:transform .2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
            <img src="images/クラフトワーク表.jpg" alt="クラフトワーク" style="width:100%; aspect-ratio:3/2; object-fit:cover; display:block;">
            <div style="padding:14px 16px;">
              <p style="font-size:.75rem; color:#c9a96e; font-weight:700; letter-spacing:.1em; margin-bottom:4px;">7月4日（土）出店</p>
              <p style="font-size:1rem; font-weight:700; color:#2c1a0e;">クラフトワーク</p>
            </div>
          </div>
        </a>
