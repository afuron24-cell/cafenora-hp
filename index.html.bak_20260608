<script>
// Live bars: 残り日数 ＋ hero-content 自動位置調整
(function(){
  var lives=[
    {id:'hachinoko',       date:'2026-06-14'},
    {id:'karitomato',       date:'2026-07-28'},
    {id:'karitomato-t1',   date:'2026-07-28'},
    {id:'torubale',       date:'2026-08-02'}
  ];
  var n=new Date(), today=new Date(n.getFullYear(),n.getMonth(),n.getDate());
  lives.forEach(function(lv){
    var p=lv.date.split('-');
    var diff=Math.round((new Date(+p[0],+p[1]-1,+p[2])-today)/86400000);
    var bar=document.getElementById('lb-'+lv.id);
    var el=document.getElementById('lbd-'+lv.id);
    if(!bar||!el) return;
    if(diff<0){ bar.style.display='none'; return; }
    if(diff===0){ el.innerHTML='<strong>本日！</strong>'; el.classList.add('lt-today'); }
    else if(diff===1){ el.innerHTML='<strong>明日</strong>'; el.classList.add('lt-today'); }
    else{ el.innerHTML='あと<strong>'+diff+'日</strong>'; }
  });
  (function(){
    var rows=[
      {rowId:'lt-row1',ids:['hachinoko','karitomato-t1'],sepId:'lbs-r1'},
      {rowId:'lt-row2',ids:['karitomato','torubale'],sepId:'lbs-r2'}
    ];
    rows.forEach(function(r){
      var vis=r.ids.map(function(id){var el=document.getElementById('lb-'+id);return el&&el.style.display!=='none';});
      var sep=document.getElementById(r.sepId);
      if(sep) sep.style.display=(vis[0]&&vis[1])?'':'none';
      var row=document.getElementById(r.rowId);
      if(row&&!vis[0]&&!vis[1]) row.style.display='none';
    });
  })();
})();
// ヒーロー：あみ太くんライブまでの残り日数（自動計算）
(function(){
  var el=document.getElementById('hero-amita-days');
  if(!el) return;
  var n=new Date(), today=new Date(n.getFullYear(),n.getMonth(),n.getDate());
  var diff=Math.round((new Date(2026,5,14)-today)/86400000);
  if(diff>0){ el.textContent='残り'+diff+'日！'; }
  else if(diff===0){ el.textContent='本日開催！'; }
  else{ el.style.display='none'; }
})();
// イベントカードのカウントダウン
(function(){
  var evs=[
    {id:'idx-hachinoko',       date:'2026-06-14'},
    {id:'idx-karitomato',       date:'2026-07-28'},
    {id:'idx-torubale',       date:'2026-08-02'}
  ];
  var n=new Date(), today=new Date(n.getFullYear(),n.getMonth(),n.getDate());
  evs.forEach(function(ev){
    var p=ev.date.split('-');
    var diff=Math.round((new Date(+p[0],+p[1]-1,+p[2])-today)/86400000);
    var el=document.getElementById('cd-'+ev.id);
    if(!el) return;
    var text,cls='event-cd-sm';
    if(diff>1){ text='🗓 あと '+diff+' 日'; }
    else if(diff===1){ text='✦ いよいよ明日！'; }
    else if(diff===0){ text='🎵 本日開催！'; cls+=' cd-today'; }
    else { return; }
    el.textContent=text; el.className=cls; el.style.display='inline-block';
  });
})();
</script>
<script>(function(){var p=new URLSearchParams(location.search);if(p.get("owner")==="nora")localStorage.setItem("nora_owner","1");if(p.get("owner")==="off")localStorage.removeItem("nora_owner");if(!localStorage.getItem("nora_owner"))fetch("https://noratool.pythonanywhere.com/pv?p="+encodeURIComponent(location.pathname)).catch(function(){});})();</script>
<script>
(function(){
  var img = document.querySelector('.hero-img');
  var hero = document.querySelector('.hero');
  if (!img || !hero) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var ticking = false;
  function update() {
    var s = window.pageYOffset;
    var h = hero.offsetHeight;
    if (s <= h) {
      var shift = Math.min(s * 0.4, h * 0.22);
      img.style.transform = 'translateY(' + shift + 'px)';
    }
    ticking = false;
  }
  window.addEventListener('scroll', function() {
    if (!ticking) { requestAnimationFrame(update); ticking = true; }
  }, { passive: true });
})();
</script>



<!-- PWAインストールバナー -->
<div id="pwa-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#1a1a2e;color:#fff;padding:14px 20px;align-items:center;justify-content:space-between;gap:12px;box-shadow:0 -4px 20px rgba(0,0,0,0.3);">
  <div style="display:flex;align-items:center;gap:10px;">
    <img src="/images/icon-192.png" width="40" height="40" style="border-radius:8px;flex-shrink:0;">
    <div>
      <div style="font-size:0.85rem;font-weight:700;">cafe nora をホーム画面に追加</div>
      <div style="font-size:0.72rem;color:rgba(255,255,255,0.6);margin-top:2px;">アプリのように使えます</div>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-shrink:0;">
    <button id="pwa-install-btn" style="background:#7a9e7e;color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:0.82rem;font-weight:700;cursor:pointer;">追加する</button>
    <button id="pwa-close-btn" style="background:rgba(255,255,255,0.12);color:#fff;border:none;border-radius:8px;padding:8px 12px;font-size:0.8rem;cursor:pointer;">✕</button>
  </div>
</div>

<!-- iOS向け手順モーダル -->
<div id="ios-modal" style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,0.6);align-items:flex-end;justify-content:center;">
  <div style="background:#fff;border-radius:20px 20px 0 0;padding:28px 24px 40px;width:100%;max-width:480px;">
    <div style="font-size:1rem;font-weight:700;color:#1a1a2e;margin-bottom:16px;text-align:center;">ホーム画面に追加する方法</div>
    <div style="font-size:0.88rem;color:#444;line-height:1.9;">
      <div>① Safari 下部の <strong>共有ボタン（四角に矢印）</strong> をタップ</div>
      <div>② 「<strong>ホーム画面に追加</strong>」を選択</div>
      <div>③ 「<strong>追加</strong>」をタップ</div>
    </div>
    <button onclick="document.getElementById('ios-modal').style.display='none';" style="margin-top:20px;width:100%;background:#7a9e7e;color:#fff;border:none;border-radius:10px;padding:14px;font-size:0.9rem;font-weight:700;cursor:pointer;">閉じる</button>
  </div>
</div>

<script>
(function(){
  // スタンドアローンモード（インストール済み）なら何もしない
  if(window.matchMedia('(display-mode: standalone)').matches) return;
  // PCは対象外
  if(!/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) return;
  // このセッションで閉じた場合はスキップ
  if(sessionStorage.getItem('pwa-dismissed')) return;

  var banner = document.getElementById('pwa-banner');
  var deferredPrompt = null;
  var isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);

  // バナーを表示
  banner.style.display = 'flex';

  // Androidの場合：beforeinstallpromptを待つ
  window.addEventListener('beforeinstallprompt', function(e){
    e.preventDefault();
    deferredPrompt = e;
  });

  document.getElementById('pwa-install-btn').addEventListener('click', function(){
    if(deferredPrompt){
      // Chrome がインストール可能と判定済み → ダイアログ表示
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(function(){
        deferredPrompt = null;
        banner.style.display = 'none';
      });
    } else if(isIOS){
      // iOS → 手順モーダル表示
      document.getElementById('ios-modal').style.display = 'flex';
    } else {
      // Android（まだChrome判定待ち）→ 手順を案内
      alert('Chromeの右上メニュー（⋮）→「アプリをインストール」または「ホーム画面に追加」をタップしてください');
    }
  });

  document.getElementById('pwa-close-btn').addEventListener('click', function(){
    banner.style.display = 'none';
    sessionStorage.setItem('pwa-dismissed', '1');
  });

  window.addEventListener('appinstalled', function(){
    banner.style.display = 'none';
  });
})();
</script>


<!-- 通知登録バナー -->
<div id="notify-banner" style="display:none;position:fixed;top:0;left:0;right:0;z-index:9998;background:#4d7350;color:#fff;padding:12px 20px;align-items:center;justify-content:space-between;gap:12px;">
  <div style="font-size:0.82rem;line-height:1.5;">
    🔔 <strong>ライブ情報をお知らせ</strong><br>
    <span style="font-size:0.72rem;opacity:0.85;">新しいライブ・イベントを通知でお届けします</span>
  </div>
  <div style="display:flex;gap:8px;flex-shrink:0;">
    <button id="notify-yes" style="background:#fff;color:#4d7350;border:none;border-radius:8px;padding:8px 14px;font-size:0.8rem;font-weight:700;cursor:pointer;white-space:nowrap;">受け取る</button>
    <button id="notify-no" style="background:rgba(255,255,255,0.2);color:#fff;border:none;border-radius:8px;padding:8px 10px;font-size:0.8rem;cursor:pointer;">×</button>
  </div>
</div>
<script>
(function(){
  if(typeof Notification === 'undefined') return;
  if(Notification.permission === 'granted') return;
  if(Notification.permission === 'denied') return;
  setTimeout(function(){
    var b = document.getElementById('notify-banner');
    if(b) b.style.display = 'flex';
  }, 3000);
  document.getElementById('notify-yes').addEventListener('click', function(){
    OneSignalDeferred.push(function(OneSignal){ OneSignal.Notifications.requestPermission(); });
    document.getElementById('notify-banner').style.display = 'none';
  });
  document.getElementById('notify-no').addEventListener('click', function(){
    document.getElementById('notify-banner').style.display = 'none';
  });
})();
</script>

</body>
