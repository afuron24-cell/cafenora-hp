<script>
(function(){
  if(window.matchMedia('(display-mode: standalone)').matches) return;
  if(!/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) return;
  if(sessionStorage.getItem('pwa-dismissed')) return;
  var banner = document.getElementById('pwa-banner');
  var deferredPrompt = null;
  var isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent);
  banner.style.display = 'flex';
  window.addEventListener('beforeinstallprompt', function(e){
    e.preventDefault();
    deferredPrompt = e;
  });
  document.getElementById('pwa-install-btn').addEventListener('click', function(){
    if(deferredPrompt){
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(function(){ deferredPrompt = null; banner.style.display = 'none'; });
    } else if(isIOS){
      document.getElementById('ios-modal').style.display = 'flex';
    } else {
      alert('Chromeの右上メニュー（⋮）→「アプリをインストール」または「ホーム画面に追加」をタップしてください');
    }
  });
  document.getElementById('pwa-close-btn').addEventListener('click', function(){
    banner.style.display = 'none';
    sessionStorage.setItem('pwa-dismissed', '1');
  });
  window.addEventListener('appinstalled', function(){ banner.style.display = 'none'; });
})();
</script>

