  <script>
  (function(){
    var evs=[{id:'hachinoko',date:'2026-06-14'},{id:'karitomato',date:'2026-07-28'},{id:'torubale',date:'2026-08-02'}];
    var n=new Date(),today=new Date(n.getFullYear(),n.getMonth(),n.getDate());
    evs.forEach(function(ev){
      var el=document.getElementById('evd-'+ev.id);
      if(!el)return;
      var p=ev.date.split('-');
      var diff=Math.round((new Date(+p[0],+p[1]-1,+p[2])-today)/86400000);
      if(diff<0){var li=el.closest('li');if(li)li.style.display='none';return;}
      if(diff===0){el.textContent='本日！';el.classList.add('ev-today');}
      else if(diff===1){el.textContent='明日';}
      else{el.textContent='あと'+diff+'日';}
    });
  })();
  </script>

