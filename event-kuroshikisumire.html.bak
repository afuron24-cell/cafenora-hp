  <script>
    /* particles */
    (function(){
      var c = document.getElementById('gs-particles');
      var s = ['✦','♪','♫','✿','❋','◈','✵','❀'];
      for(var i=0;i<28;i++){
        var el=document.createElement('span');
        el.className='gs-particle';
        el.textContent=s[Math.floor(Math.random()*s.length)];
        el.style.left=Math.random()*100+'%';
        el.style.fontSize=(Math.random()*.9+.5)+'rem';
        el.style.animationDuration=(Math.random()*14+10)+'s';
        el.style.animationDelay=(Math.random()*12)+'s';
        c.appendChild(el);
      }
    })();

    /* countdown */
    (function(){
      var liveDate=new Date('2026-06-05T00:00:00+09:00');
      var now=new Date();
      var jstMs=now.getTime()+9*3600000;
      var todayJST=new Date(Math.floor(jstMs/86400000)*86400000-9*3600000);
      var diff=Math.round((liveDate-todayJST)/86400000);
      var el=document.getElementById('hero-days');
      if(diff>0){
        el.textContent=diff;
        if(diff<=7) document.getElementById('urgency-banner').classList.remove('hidden');
      } else {
        document.querySelector('.gs-hero-cd').textContent='開催当日！';
      }
    })();

    /* scroll fade-in */
    (function(){
      var obs=new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }
        });
      },{threshold:.1});
      document.querySelectorAll('.fade-in').forEach(function(el){ obs.observe(el); });
    })();
  </script>
  <script>(function(){var p=new URLSearchParams(location.search);if(p.get("owner")==="nora")localStorage.setItem("nora_owner","1");if(p.get("owner")==="off")localStorage.removeItem("nora_owner");if(!localStorage.getItem("nora_owner"))fetch("https://noratool.pythonanywhere.com/pv?p="+encodeURIComponent(location.pathname)).catch(function(){});})();</script>
</body>
</html>
